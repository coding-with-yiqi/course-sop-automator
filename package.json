{
  "name": "course-sop-automator",
  "private": true,
  "version": "0.1.1",
  "description": "AI-powered video to SOP document pipeline",
  "author": "Course SOP Team",
  "main": "electron/dist/bootstrap.cjs",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c green,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "dev:electron": "NODE_ENV=development electron electron/dist/bootstrap.cjs",
    "build:server": "npm --workspace shared run build && node scripts/build-server.js",
    "build": "npm --workspace shared run build && npm --workspace web run build && npm run build:server",
    "build:electron": "tsc -p electron/tsconfig.json && cp electron/bootstrap.cjs electron/dist/bootstrap.cjs",
    "dist": "npm run build && npm run build:electron && electron-builder",
    "dist:mac": "npm run build && npm run build:electron && electron-builder --mac",
    "dist:win": "npm run build && npm run build:electron && electron-builder --win",
    "download:ffmpeg": "node scripts/download-ffmpeg.js",
    "start": "node server/dist/index.js",
    "db:migrate": "npm --workspace server run db:migrate",
    "test": "npm --workspace server run test && npm --workspace web run test && npm run test:electron",
    "test:electron": "vitest run --config electron/vitest.config.ts",
    "test:e2e": "npm --workspace web run test:e2e",
    "test:e2e:electron": "npm --workspace web run test:e2e:electron",
    "test:coverage": "npm --workspace server run test:coverage && npm --workspace web run test:coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "@img/sharp-darwin-arm64": "0.33.5",
    "@img/sharp-libvips-darwin-arm64": "1.0.4",
    "@notionhq/client": "^5.22.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "electron-updater": "^6.6.0",
    "execa": "^9.5.1",
    "fastify": "^4.28.1",
    "form-data": "^4.0.5",
    "handlebars": "^4.7.9",
    "nanoid": "^5.1.11",
    "openai": "^4.104.0",
    "p-limit": "^5.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "pizzip": "^3.2.0",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.33.5",
    "subtitle": "^4.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.28.0"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.sop-automator.app",
    "productName": "Course SOP Automator",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/dist/**/*",
      "server/dist/index.js",
      "web/dist/**/*",
      "package.json",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/color/**/*",
      "node_modules/color-convert/**/*",
      "node_modules/color-name/**/*",
      "node_modules/color-string/**/*",
      "node_modules/is-arrayish/**/*",
      "node_modules/simple-swizzle/**/*",
      "node_modules/semver/**/*",
      "node_modules/detect-libc/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "server/dist/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/color/**/*",
      "node_modules/color-convert/**/*",
      "node_modules/color-name/**/*",
      "node_modules/color-string/**/*",
      "node_modules/is-arrayish/**/*",
      "node_modules/simple-swizzle/**/*",
      "node_modules/semver/**/*",
      "node_modules/detect-libc/**/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
