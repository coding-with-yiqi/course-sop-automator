# Kimi (Moonshot) LLM.
# Two modes:
# (A) Kimi Coding Plan key (prefix "sk-kimi-"): point to api.kimi.com/coding/v1.
#     UA must mimic a supported coding agent (claude-cli/...).
# (B) Moonshot Platform key (prefix "sk-"): point to api.moonshot.cn/v1.
KIMI_API_KEY=sk-kimi-xxxxxxxxxxxxxxxxxxxxx
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-for-coding
KIMI_USER_AGENT=claude-cli/1.0

PORT=4000
DATA_DIR=./data
LOG_LEVEL=info

# Optional — only needed at M7 (multi-platform sync).
# Leave blank to disable; the UI will prompt to configure.
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
YUQUE_TOKEN=
YUQUE_NAMESPACE=
