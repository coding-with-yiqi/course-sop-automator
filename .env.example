# AI API Key — 三选一，优先顺序: Kimi > DeepSeek > OpenAI
# 填一个即可，系统在设置页会自动识别

# Kimi (推荐中文课程)
# 获取: https://kimi.com → 开发者中心
KIMI_API_KEY=sk-kimi-xxxxxxxxxxxxxxxxxxxxx
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-for-coding
KIMI_USER_AGENT=claude-cli/1.0

# DeepSeek (性价比高)
# 获取: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_USER_AGENT=sop-automator/1.0

# OpenAI (GPT-4o 等)
# 获取: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_USER_AGENT=sop-automator/1.0

PORT=4000
DATA_DIR=./data
LOG_LEVEL=info
